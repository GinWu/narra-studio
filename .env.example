# Narra Studio local development defaults.
# Do not put real provider API keys in this file.

AIWM_ENV=development
AIWM_SERVICE_NAME=api
AIWM_API_HOST=0.0.0.0
AIWM_API_PORT=8000
AIWM_API_PUBLISHED_PORT=8000
AIWM_WEB_PUBLISHED_PORT=8501
AIWM_WORKSPACE_ROOT=/app/workspace
AIWM_DATABASE_URL=postgresql://aiwm:aiwm_dev_password@db:5432/aiwm
AIWM_SQLITE_DEV_URL=sqlite:////tmp/aiwm-dev.db
AIWM_REDIS_URL=redis://redis:6379/0
AIWM_LOG_LEVEL=INFO
AIWM_ENABLE_AUTO_MIGRATIONS=false
